# Enable javstash (JAV scene metadata via Stash-Box GraphQL)
# Get your key from https://javstash.org user settings
JAVSTASH_API_KEY=
JAVSTASH_ENDPOINT=https://javstash.org/graphql

# Enable pmvstash (PMV scene metadata via Stash-Box GraphQL)
# Get your key from https://pmvstash.org user settings
PMVSTASH_API_KEY=
PMVSTASH_ENDPOINT=https://pmvstash.org/graphql

# Enable javdb fallback (HTML scraper, used when javstash returns no match for a JAV code)
# No API key needed; set to "true" to enable
JAVDB_ENABLED=false
JAVDB_BASE_URL=https://javdb.com

# Cache settings (defaults shown)
# Disk cache directory; ~ is expanded. Leave empty to disable disk layer.
CACHE_DIR=~/.cache/movie-db-mcp
# TTL in seconds; defaults to 1 hour
CACHE_TTL_SECONDS=3600
# Max in-memory items
CACHE_MAX_ITEMS=500

# Optional: log level (silent | error | warn | info | debug)
LOG_LEVEL=info
